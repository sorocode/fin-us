# NAT (default for /api/v1/analyze when provider=nat)
NAT_BASE_URL=http://127.0.0.1:8000
# Docker Compose (repository root docker-compose.yml) sets NAT_BASE_URL=http://finus-nat:8000 for the backend service.
# Must match a tag in Ollama (`ollama list`). Docker Compose overrides this with OLLAMA_MODEL for the backend service.
NAT_CHAT_MODEL=qwen3.5:9b

# OpenAI — used when analyze ?provider=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Anthropic — used when analyze ?provider=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
