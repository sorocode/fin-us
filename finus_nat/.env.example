# NeMo Agent Toolkit (finus_nat) — 로컬 비밀 예시.
# 복사: cp .env.example .env 후 값 채우기.
# run.sh 가 backend/.env → fin-us/.env → 이 파일 순으로 로드합니다.

# Mem0 (examples/agents/auto_memory_wrapper 와 동일 — export MEM0_API_KEY=<키>)
MEM0_API_KEY=

